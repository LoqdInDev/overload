# ── Core ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
DB_PATH=./overload.db
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
ENCRYPTION_KEY=your-random-string-at-least-32-characters-long
JWT_SECRET=your-strong-random-jwt-secret-at-least-64-characters

# ── Email (SMTP) ──────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@overload.app

# ── CORS ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── OAuth Callback Base URL ──────────────────────────
# Set to your production URL when deploying
OAUTH_CALLBACK_URL=http://localhost:3000

# ── Google (Ads, Analytics, YouTube) ─────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Meta (Facebook/Instagram) ──────────────────────
META_CLIENT_ID=
META_CLIENT_SECRET=

# ── Twitter / X ─────────────────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── LinkedIn ────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── TikTok ──────────────────────────────────────────
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# ── Shopify ──────────────────────────────────────────
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# ── Stripe Billing ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
